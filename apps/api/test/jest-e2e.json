{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": ".",
  "testEnvironment": "node",
  "testRegex": ".e2e-spec.ts$",
  "transform": {
    "^.+\\.(t|j)s$": ["ts-jest", {
      "tsconfig": "<rootDir>/../tsconfig.json"
    }]
  },
  "setupFiles": ["<rootDir>/jest.env.setup.js"],
  "testTimeout": 30000
}
