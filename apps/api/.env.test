# ── E2E test environment — used by jest --config test/jest-e2e.json ──────────
NODE_ENV=test

# ── Database ──────────────────────────────────────────────────────────────────
# Separate database keeps E2E tests isolated from dev data.
# Create it once: psql -U trazabilidad -c "CREATE DATABASE trazabilidad_test;"
DB_HOST=localhost
DB_PORT=5432
DB_USER=trazabilidad
DB_PASSWORD=trazabilidad
DB_NAME=trazabilidad_test
DB_LOGGING=false

# ── API ───────────────────────────────────────────────────────────────────────
API_PORT=4001
CORS_ORIGINS=http://localhost:3000

# ── Throttling — very high limits so tests never hit rate caps ────────────────
THROTTLE_TTL_MS=60000
THROTTLE_LIMIT=9999

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=e2e-test-jwt-secret-must-be-32chars-min
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=e2e-test-refresh-secret-32chars-min!!
JWT_REFRESH_EXPIRES_IN=7d

# ── AFIP / Redis / Email — all mocked / disabled for tests ───────────────────
AFIP_ENV=mock
REDIS_HOST=localhost
REDIS_PORT=6379
APP_URL=http://localhost:3000
