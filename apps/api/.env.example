# ── Database ──────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USER=trazabilidad
DB_PASSWORD=trazabilidad
DB_NAME=trazabilidad
# DB_SYNC is intentionally removed — synchronize is hardcoded to false.
# Schema changes must be handled via migrations (pnpm --filter api migration:run).
DB_LOGGING=false     # Set true to log SQL queries in dev

# ── API ───────────────────────────────────────────────────────────────────────
API_PORT=4000
CORS_ORIGINS=http://localhost:3000   # comma-separated list of allowed origins

# ── Rate limiting ─────────────────────────────────────────────────────────────
THROTTLE_TTL_MS=60000   # window in milliseconds (default 60 s)
THROTTLE_LIMIT=120      # max requests per window per IP (auth routes use 10)

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-in-production-min-32-chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-me-too-in-production-min-32-chars
JWT_REFRESH_EXPIRES_IN=7d

# ── AFIP / ARCA ───────────────────────────────────────────────────────────────
# Set to "mock" for development, "homologacion" or "produccion" for real AFIP
AFIP_ENV=mock

# Required when AFIP_ENV != mock:
# AFIP_CERT_PATH=/secrets/afip-cert.pem
# AFIP_KEY_PATH=/secrets/afip-key.pem
# AFIP_CUIT=20-12345678-9

# ── Redis (optional — token blacklist degrades gracefully if absent) ──────────
REDIS_HOST=localhost
REDIS_PORT=6379

# ── PDF / Company info ────────────────────────────────────────────────────────
# Shown on invoice PDFs (AFIP_CUIT is also used as issuer CUIT on PDFs)
# COMPANY_ADDRESS=Av. Ejemplo 1234, Buenos Aires

# ── Email / SMTP (optional — logs to console if SMTP_HOST is absent) ─────────
# Resend: SMTP_HOST=smtp.resend.com SMTP_PORT=465 SMTP_SECURE=true SMTP_USER=resend SMTP_PASS=re_xxxxx
# Gmail:  SMTP_HOST=smtp.gmail.com  SMTP_PORT=587 SMTP_SECURE=false SMTP_USER=you@gmail.com SMTP_PASS=app_password
# SMTP_HOST=smtp.resend.com
# SMTP_PORT=465
# SMTP_SECURE=true
# SMTP_USER=resend
# SMTP_PASS=re_YOUR_API_KEY
# EMAIL_FROM=Trazabilidad ERP <noreply@yourdomain.com>
APP_URL=http://localhost:3000
