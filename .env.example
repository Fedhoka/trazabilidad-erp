NODE_ENV=development
API_PORT=4000
WEB_PORT=3000
API_URL=http://localhost:4000
WEB_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000

DB_HOST=localhost
DB_PORT=5432
DB_USER=trazabilidad
DB_PASSWORD=trazabilidad
DB_NAME=trazabilidad
DB_SYNC=false
DB_LOGGING=false

REDIS_URL=redis://localhost:6379

JWT_SECRET=change-me-32-chars-min-xxxxxxxxxxxxxxxx
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-me-too-32-chars-xxxxxxxxxxx
JWT_REFRESH_EXPIRES_IN=7d

AFIP_ENV=mock
AFIP_CUIT=20123456789
AFIP_CERT_PATH=./secrets/afip.crt
AFIP_KEY_PATH=./secrets/afip.key

# ── Nginx / SSL (production only) ────────────────────────────────────────────
# Domain that Nginx listens on and that Certbot obtains a certificate for.
# Must have a DNS A record pointing to this server before running
# scripts/init-letsencrypt.sh
DOMAIN=erp.yourdomain.com
SSL_EMAIL=admin@yourdomain.com
